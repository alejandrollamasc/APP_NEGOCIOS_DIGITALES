{
  "home": {
    "html": "\n    <div class=\"home-page\" style=\"\">\n      <!-- ========== TOP TABS BAR (dark green) ========== -->\n      <div class=\"sb-top-bar\">\n        <div class=\"sb-top-bar__inner\" style=\"\">\n          <div class=\"sb-top-bar__tabs\" style=\"\">\n            <a href=\"#\" class=\"sb-top-bar__tab sb-top-bar__tab--active\">PERSONAS</a>\n            <a href=\"https://www.segurosbolivar.com/empresas\" target=\"_blank\" class=\"sb-top-bar__tab\" style=\"\">EMPRESAS</a>\n            <a href=\"https://www.segurosbolivar.com/arl\" target=\"_blank\" class=\"sb-top-bar__tab\" style=\"\">ARL</a>\n            <a href=\"https://www.segurosbolivar.com/clientes-davivienda\" target=\"_blank\" class=\"sb-top-bar__tab\" style=\"\">CLIENTES DAVIVIENDA</a>\n          </div>\n          <a href=\"#\" class=\"sb-top-bar__search\" style=\"\">\n            BUSCAR\n            <svg width=\"15\" height=\"14\" viewBox=\"0 0 15 14\" fill=\"none\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4.28572 8.8H4.97143L5.22854 8.56C4.3714 7.68 3.85711 6.48 3.85711 5.2C3.85714 2.32 6.34286 0 9.42857 0C12.5143 0 15 2.32 15 5.2C15 8.08 12.5143 10.4 9.42857 10.4C8.05714 10.4 6.77143 9.92 5.82857 9.12L5.57143 9.35997V9.99997L1.28571 14L0 12.8L4.28572 8.8ZM9.42857 8.8C11.5714 8.8 13.2857 7.2 13.2857 5.2C13.2857 3.2 11.5714 1.6 9.42857 1.6C7.28571 1.6 5.57143 3.2 5.57143 5.2C5.57143 7.2 7.28571 8.8 9.42857 8.8Z\" fill=\"#FFDC5D\"></path></svg>\n          </a>\n        </div>\n      </div>\n\n      <!-- ========== MAIN NAVBAR (white) ========== -->\n      <nav class=\"sb-navbar\">\n        <div class=\"sb-navbar__inner\" style=\"\">\n          <a href=\"https://www.segurosbolivar.com\" target=\"_blank\" class=\"sb-navbar__logo\" aria-label=\"Seguros Bolivar\">\n            <img src=\"/images/logo-seguros-bolivar.png\" alt=\"Seguros Bolivar\" class=\"sb-navbar__logo-img\" style=\"display: none;\">\n          </a>\n          <div class=\"sb-navbar__links\" style=\"\">\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"display: none;\">Vehiculos <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\"></path></svg></a>\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"\">Hogar <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\" style=\"\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\"></path></svg></a>\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"display: none;\">Vida <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\"></path></svg></a>\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"display: none;\">Salud <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\" style=\"\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\" style=\"\"></path></svg></a>\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"display: none;\">Titulos de capitalizacion <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\"></path></svg></a>\n            <a href=\"#\" class=\"sb-navbar__link\" style=\"display: none;\">Otras alianzas <svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\"><path d=\"M1 1l4 4 4-4\" stroke=\"currentColor\" stroke-width=\"1.5\" fill=\"none\" stroke-linecap=\"round\"></path></svg></a>\n          </div>\n          <div class=\"sb-navbar__actions\" style=\"\">\n            <a href=\"#\" class=\"sb-navbar__action sb-navbar__action--payments\" style=\"\">REALICE SUS PAGOS</a>\n            <a href=\"#\" class=\"sb-navbar__action sb-navbar__action--access\" style=\"display: none;\">ACCESO A CLIENTES</a>\n          </div>\n          <button class=\"sb-navbar__hamburger\" aria-label=\"Menu\">\n            <span></span><span></span><span></span>\n          </button>\n        </div>\n      </nav>\n\n      <!-- ========== BREADCRUMB ========== -->\n      <div class=\"hogar-breadcrumb\" style=\"\">\n        <div class=\"hogar-breadcrumb__inner\">\n          <a href=\"#\" class=\"hogar-breadcrumb__link\">Inicio</a>\n          <span class=\"hogar-breadcrumb__sep\">&gt;</span>\n          <a href=\"#\" class=\"hogar-breadcrumb__link\">Seguros en linea</a>\n          <span class=\"hogar-breadcrumb__sep\">&gt;</span>\n          <span class=\"hogar-breadcrumb__current\" style=\"\">Seguro Hogar</span>\n        </div>\n      </div>\n\n      <!-- ========== HERO BANNER ========== -->\n      <section class=\"hogar-hero\">\n        <div class=\"hogar-hero__bg\" style=\"position: relative;\">\n          <img src=\"/images/banner-hogar-pareja.jpg\" alt=\"Seguro Hogar Banner\" class=\"hogar-hero__img\" style=\"\">\n        <div class=\"hogar-hero__form\" style=\"position: absolute; z-index: 99999; left: 922.848px; top: 58.9258px;\">\n            <h2 class=\"hogar-hero__form-title\">¡Cotice aquí!</h2>\n            <form id=\"hogar-form\" novalidate=\"\">\n              <div class=\"form-group\" style=\"\">\n                <label class=\"form-label\" for=\"hogar-property\">¿Es propietario de la vivienda?</label>\n                <select id=\"hogar-property\" class=\"hogar-select\" required=\"\" style=\"\">\n                  <option value=\"propietario-vive\">Soy propietario y vivo en ella</option>\n                  <option value=\"propietario-no-vive\">Soy propietario y no vivo en ella</option>\n                  <option value=\"arrendatario\">Soy arrendatario</option>\n                </select>\n              </div>\n              <div class=\"form-group\" style=\"\">\n                <label class=\"form-label\" for=\"hogar-email\">Correo electrónico</label>\n                <input type=\"email\" id=\"hogar-email\" class=\"sb-ui-input\" placeholder=\"Ej: correo@correo.com\" required=\"\" style=\"\">\n              </div>\n              <div class=\"hogar-hero__checks\">\n                <label class=\"hogar-hero__check\">\n                  <input type=\"checkbox\" id=\"hogar-data\" required=\"\">\n                  <span style=\"\">Autorizo la utilización de mis datos personales con <a href=\"#\" class=\"link-green\">fines comerciales</a>.</span>\n                </label>\n              </div>\n              <div class=\"hogar-hero__form-action\" style=\"\">\n                <button type=\"submit\" class=\"hogar-hero__submit\">Cotizar mi seguro</button>\n              </div>\n            </form>\n          </div></div>\n        <div class=\"hogar-hero__inner\" style=\"\">\n          <!-- Left content (694px) -->\n          <div class=\"hogar-hero__left\" style=\"\">\n            <div class=\"hogar-hero__badge\" style=\"display: none;\">¡NUEVO!</div>\n            <div class=\"hogar-hero__card\" style=\"\">\n              <p class=\"hogar-hero__card-subtitle\" style=\"\">Seguro de Hogar</p>\n              <h1 class=\"hogar-hero__card-title\" style=\"\">Asegure su casa en minutos y 100% en línea</h1>\n              <p class=\"hogar-hero__card-desc\">Cotice y conozca todas nuestras coberturas</p>\n            </div>\n          </div>\n          <!-- Right form (343px) -->\n          \n        </div>\n      </section>\n\n      <!-- ========== STEPPER ========== -->\n      \n\n      <!-- ========== VALUE PROPOSITION ========== -->\n      <section class=\"hogar-value\">\n        <div class=\"hogar-value__inner\" style=\"position: relative; display: none;\">\n          <div class=\"hogar-value__image\" style=\"position: relative;\">\n            <img src=\"/images/pareja-feliz-hogar.jpg\" alt=\"Familia feliz en su hogar\" style=\"display: none;\">\n          <section class=\"hogar-stepper\" style=\"position: absolute; z-index: 99999; left: 0px; top: 4px; display: none;\">\n        <h2 class=\"hogar-section-title\">¡Adquiera su seguro en pocos pasos!</h2>\n        <div class=\"hogar-stepper__frame\" style=\"\">\n          <div class=\"hogar-stepper__line hogar-stepper__line--1\"></div>\n          <div class=\"hogar-stepper__line hogar-stepper__line--2\"></div>\n          <div class=\"hogar-stepper__line hogar-stepper__line--3\"></div>\n          <div class=\"hogar-stepper__step\" style=\"left: 126px;\">\n            <div class=\"hogar-stepper__bull\">\n              <span class=\"hogar-stepper__number\">1</span>\n            </div>\n            <p class=\"hogar-stepper__label\">Ingrese sus datos</p>\n          </div>\n          <div class=\"hogar-stepper__step\" style=\"left: 288px;\">\n            <div class=\"hogar-stepper__bull\">\n              <span class=\"hogar-stepper__number\">2</span>\n            </div>\n            <p class=\"hogar-stepper__label\">Arme su plan</p>\n          </div>\n          <div class=\"hogar-stepper__step\" style=\"left: 450px;\">\n            <div class=\"hogar-stepper__bull\">\n              <span class=\"hogar-stepper__number\">3</span>\n            </div>\n            <p class=\"hogar-stepper__label\">Confirme su compra</p>\n          </div>\n          <div class=\"hogar-stepper__step\" style=\"left: 612px;\">\n            <div class=\"hogar-stepper__bull\">\n              <span class=\"hogar-stepper__number\">4</span>\n            </div>\n            <p class=\"hogar-stepper__label\">Pague su seguro</p>\n          </div>\n        </div>\n      </section></div>\n          <div class=\"hogar-value__content\" style=\"\">\n            <div class=\"hogar-value__badge\" style=\"display: none;\">\n              <img src=\"/images/icon-mapa.png\" alt=\"Mapa Colombia\" class=\"hogar-value__badge-icon\">\n              <div class=\"hogar-value__badge-group\" style=\"display: none;\">\n                <span class=\"hogar-value__badge-masde\">Más de</span>\n                <span class=\"hogar-value__badge-300\">300</span>\n                <span class=\"hogar-value__badge-mil\">Mil</span>\n                <span class=\"hogar-value__badge-hogares\" style=\"display: none;\">hogares asegurados</span>\n              </div>\n            </div>\n            \n          </div>\n        <div class=\"hogar-value__text-block\" style=\"position: absolute; z-index: 99999; left: 611.473px; top: 110.984px; display: none;\">\n              <h2 class=\"hogar-value__title\" style=\"display: none;\">\"Cada hogar es un mundo distinto\"</h2>\n              <p class=\"hogar-value__desc\" style=\"display: none;\">Por eso creamos un seguro que se ajusta a las necesidades de su familia.</p>\n            </div></div>\n      </section>\n\n      <!-- ========== COVERAGES ========== -->\n      <section class=\"hogar-coverages\" style=\"\">\n        <div class=\"hogar-coverages__header\" style=\"\">\n          <h2 class=\"hogar-coverages__title\" style=\"\">¡Conozca nuestras coberturas y configúrelas a su medida!</h2>\n        </div>\n        <!-- Row 1 -->\n        <div class=\"hogar-coverages__row\">\n          <div class=\"hogar-coverages__card\" style=\"\">\n            <img src=\"/Iconos/Icono_Vigilancia.png\" alt=\"\" class=\"hogar-coverages__icon\">\n            <div class=\"hogar-coverages__text\" style=\"\">\n              <h3 class=\"hogar-coverages__name\" style=\"\">Bienestar para su familia y colaboradores domésticos</h3>\n              <p class=\"hogar-coverages__desc\">Cuente con una asistencia en caso de alguna eventualidad en su hogar.</p>\n            </div>\n          </div>\n          <div class=\"hogar-coverages__card\" style=\"\">\n            <img src=\"/Iconos/image 284.png\" alt=\"\" class=\"hogar-coverages__icon\" style=\"\">\n            <div class=\"hogar-coverages__text\">\n              <h3 class=\"hogar-coverages__name\" style=\"\">Desastres naturales</h3>\n              <p class=\"hogar-coverages__desc\" style=\"\">Mantenga a salvo su hogar de daños ocasionados por terremotos, lluvia, granizo o vientos fuertes.</p>\n            </div>\n          </div>\n        </div>\n        <!-- Row 2 -->\n        <div class=\"hogar-coverages__row\">\n          <div class=\"hogar-coverages__card\" style=\"\">\n            <img src=\"/Iconos/image 284.png\" alt=\"\" class=\"hogar-coverages__icon\" style=\"\">\n            <div class=\"hogar-coverages__text\" style=\"\">\n              <h3 class=\"hogar-coverages__name\" style=\"\">Fenómenos sociales</h3>\n              <p class=\"hogar-coverages__desc\" style=\"\">Su hogar estará siempre seguro ante daños ocasionados por desorden público o actos de terrorismo.</p>\n            </div>\n          </div>\n          <div class=\"hogar-coverages__card\" style=\"\">\n            <img src=\"/Iconos/Group 1784.png\" alt=\"\" class=\"hogar-coverages__icon\">\n            <div class=\"hogar-coverages__text\">\n              <h3 class=\"hogar-coverages__name\">Robo de pertenencias y objetos dentro de su hogar</h3>\n              <p class=\"hogar-coverages__desc\" style=\"\">Protegemos sus pertenencias ante daños o hurtos dentro y fuera de su hogar, de acuerdo a la cobertura adquirida.</p>\n            </div>\n          </div>\n        </div>\n        <!-- Row 3 -->\n        <div class=\"hogar-coverages__row\">\n          <div class=\"hogar-coverages__card\" style=\"\">\n            <img src=\"/Iconos/Group 1784.png\" alt=\"\" class=\"hogar-coverages__icon\">\n            <div class=\"hogar-coverages__text\" style=\"\">\n              <h3 class=\"hogar-coverages__name\" style=\"\">Cobertura extendida para hurto</h3>\n              <p class=\"hogar-coverages__desc\" style=\"\">Cubre la pérdida de objetos electrónicos asegurados, fuera de la vivienda causados por robos violentos.</p>\n            </div>\n          </div>\n          <div class=\"hogar-coverages__card\">\n            <img src=\"/Iconos/Frame 180.png\" alt=\"\" class=\"hogar-coverages__icon\">\n            <div class=\"hogar-coverages__text\">\n              <h3 class=\"hogar-coverages__name\">Daños accidentales a la estructura</h3>\n              <p class=\"hogar-coverages__desc\">Cubre posibles accidentes que dañen su hogar como caída de aviones, choque de autos o caída de árboles.</p>\n            </div>\n          </div>\n        </div>\n        <!-- Link -->\n        <div class=\"hogar-coverages__link-wrap\" style=\"\">\n          <a href=\"#\" class=\"hogar-coverages__link\" style=\"\">Ver todas las coberturas</a>\n        </div>\n      </section>\n\n      <!-- ========== ASSISTANCES ========== -->\n      <section class=\"hogar-assistances\" style=\"\">\n        <div class=\"hogar-assistances__header\" style=\"\">\n          <h2 class=\"hogar-assistances__title\" style=\"\">Estas asistencias seguro le ayudarán a salir de apuros</h2>\n        </div>\n        <!-- Row 1 -->\n        <div class=\"hogar-assistances__row\">\n          <div class=\"hogar-assistances__card\" style=\"\">\n            <img src=\"/Iconos/icono_plomería.png\" alt=\"\" class=\"hogar-assistances__icon\">\n            <div class=\"hogar-assistances__text\">\n              <h3 class=\"hogar-assistances__name\">Plomería 24/7</h3>\n              <p class=\"hogar-assistances__desc\">Reparamos esas goteras que no lo dejan dormir.</p>\n            </div>\n          </div>\n          <div class=\"hogar-assistances__card\" style=\"\">\n            <img src=\"/Iconos/Group 49.png\" alt=\"\" class=\"hogar-assistances__icon\">\n            <div class=\"hogar-assistances__text\">\n              <h3 class=\"hogar-assistances__name\">Cerrajería</h3>\n              <p class=\"hogar-assistances__desc\">No se preocupe si dejó las llaves dentro del carro, nosotros lo ayudamos.</p>\n            </div>\n          </div>\n        </div>\n        <!-- Row 2 -->\n        <div class=\"hogar-assistances__row\">\n          <div class=\"hogar-assistances__card\" style=\"\">\n            <img src=\"/Iconos/Group 142.png\" alt=\"\" class=\"hogar-assistances__icon\">\n            <div class=\"hogar-assistances__text\">\n              <h3 class=\"hogar-assistances__name\">Reparación de vidrios</h3>\n              <p class=\"hogar-assistances__desc\">Que los balonazos no lo tomen por sorpresa, le ayudamos a reparar esos vidrios rotos.</p>\n            </div>\n          </div>\n          <div class=\"hogar-assistances__card\" style=\"\">\n            <img src=\"/Iconos/Icono_Orientación jurídica telefónica.png\" alt=\"\" class=\"hogar-assistances__icon\">\n            <div class=\"hogar-assistances__text\">\n              <h3 class=\"hogar-assistances__name\">Asesoría jurídica y legal</h3>\n              <p class=\"hogar-assistances__desc\">¿Sus vecinos hacen mucho ruido? Con nuestra asesoría legal la tranquilidad volverá a su hogar.</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- ========== CTA SECTION ========== -->\n      <section class=\"hogar-cta-mid\" style=\"\">\n        <div class=\"hogar-cta-mid__inner\" style=\"\">\n          <h2 class=\"hogar-cta-mid__title\">¿Quiere conocer más detalles?</h2>\n          <p class=\"hogar-cta-mid__desc\">Consulte los <a href=\"#\" class=\"link-green\">Términos y Condiciones del seguro</a></p>\n        </div>\n      </section>\n\n      <!-- ========== HOW TO USE ========== -->\n      <section class=\"hogar-howto\">\n        <div class=\"hogar-howto__inner\" style=\"\">\n          <div class=\"hogar-howto__left\" style=\"\">\n            <h2 class=\"hogar-howto__title\">Conozca cómo usar su seguro</h2>\n            <p class=\"hogar-howto__desc\" style=\"\">Cuando necesite solicitar un servicio, reportar un evento o realizar un trámite de su seguro:</p>\n            <p class=\"hogar-howto__desc\" style=\"\">Comuníquese desde su celular al <strong>#322</strong>, marque las opciones <strong>1-2-2</strong> y cuéntenos qué trámites desea realizar. Nosotros lo asesoraremos para llevar a cabo su solicitud.</p>\n            <p class=\"hogar-howto__desc\">Cuando necesite solicitar un servicio, reportar un evento o realizar un trámite de su seguro:</p>\n            <p class=\"hogar-howto__desc\" style=\"\">Comuníquese desde su celular al <strong>#322</strong>, marque las opciones <strong style=\"\">1-2-2</strong> y cuéntenos qué trámites desea realizar. Nosotros lo asesoraremos para llevar a cabo su solicitud.</p>\n          </div>\n          <div class=\"hogar-howto__right\">\n            <img src=\"/images/Como-usar-seguro.jpg\" alt=\"Cómo usar su seguro de hogar\" class=\"hogar-howto__image\" style=\"\">\n          </div>\n        </div>\n      </section>\n\n      <!-- ========== EXCLUSIONS ========== -->\n      <section class=\"hogar-exclusions\">\n        <div class=\"hogar-exclusions__inner\">\n          <div class=\"hogar-exclusions__left\">\n            <div class=\"hogar-exclusions__header\">\n              <h2 class=\"hogar-exclusions__title\">¿Qué no le cubre su seguro?</h2>\n              <p class=\"hogar-exclusions__subtitle\">Resolvemos sus inquietudes al instante.</p>\n            </div>\n            <!-- Accordion 1 -->\n            <div class=\"hogar-exclusions__item\" data-exclusion=\"0\">\n              <div class=\"hogar-exclusions__item-header\">\n                <span class=\"hogar-exclusions__item-title\">Daños al inmueble a causa de terceros, mal uso o abandono</span>\n                <svg class=\"hogar-exclusions__icon-expand\" width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><path d=\"M4 7l5 5 5-5\" stroke=\"#016D38\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n              </div>\n              <div class=\"hogar-exclusions__item-body\">\n                <p>• Daños malintencionados por parte de terceros. <em>(Los daños ocasionados por arrendatarios no se contemplan).</em></p>\n                <p>• Daños ocasionados por el mal uso que usted su familia o sus empleados hagan de la vivienda.</p>\n                <p>• Daños causados por el abandono o ausencia prolongada de un residente.</p>\n              </div>\n            </div>\n            <div class=\"hogar-exclusions__separator\"></div>\n            <!-- Accordion 2 -->\n            <div class=\"hogar-exclusions__item\" data-exclusion=\"1\">\n              <div class=\"hogar-exclusions__item-header\">\n                <span class=\"hogar-exclusions__item-title\">Daños por desastres naturales provocados</span>\n                <svg class=\"hogar-exclusions__icon-expand\" width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><path d=\"M4 7l5 5 5-5\" stroke=\"#016D38\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n              </div>\n              <div class=\"hogar-exclusions__item-body\">\n                <p>• Como desastres naturales causados por pruebas nucleares, incorrecta construcción o mala impermeabilización de la vivienda.</p>\n                <p>• Terremotos provocados por vibraciones o movimientos nucleares en el subsuelo.</p>\n                <p>• Daños por movimientos de la tierra, provocados por una guerra internacional.</p>\n              </div>\n            </div>\n            <div class=\"hogar-exclusions__separator\"></div>\n            <!-- Accordion 3 -->\n            <div class=\"hogar-exclusions__item\" data-exclusion=\"2\">\n              <div class=\"hogar-exclusions__item-header\">\n                <span class=\"hogar-exclusions__item-title\">Errores de construcción, deterioro natural y falta de mantenimiento</span>\n                <svg class=\"hogar-exclusions__icon-expand\" width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><path d=\"M4 7l5 5 5-5\" stroke=\"#016D38\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n              </div>\n              <div class=\"hogar-exclusions__item-body\">\n                <p>• Los daños provocados por falta de mantenimiento.</p>\n                <p>• Los daños que tenga su casa y que hayan sido causados por errores de diseño durante la construcción.</p>\n                <p>• Daños que se reflejan debido a circunstancias ambientales o atmosféricas (hongos, corrosión, humedades como nivel freático, que son propias de la construcción).</p>\n                <p>• Daños originados durante la construcción o provenientes de errores de diseño, ensambles de materiales, calidad de materiales, falta de elementos de los sistemas constructivos y/o defectos constructivos.</p>\n              </div>\n            </div>\n            <div class=\"hogar-exclusions__separator\"></div>\n            <!-- Accordion 4 -->\n            <div class=\"hogar-exclusions__item\" data-exclusion=\"3\">\n              <div class=\"hogar-exclusions__item-header\">\n                <span class=\"hogar-exclusions__item-title\">Objetos de terceros o personas que no estén incluidas en su seguro</span>\n                <svg class=\"hogar-exclusions__icon-expand\" width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><path d=\"M4 7l5 5 5-5\" stroke=\"#016D38\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n              </div>\n              <div class=\"hogar-exclusions__item-body\">\n                <p>• Los bienes que no hayan sido incluidos o reportados dentro del seguro.</p>\n                <p>• Los bienes de uso comercial, industrial y profesional.</p>\n                <p>• Los daños o robos de objetos que no pertenezcan al asegurado.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"hogar-exclusions__right\">\n            <img src=\"/images/que-no-cubre.jpg\" alt=\"Qué no cubre su seguro\" class=\"hogar-exclusions__image\">\n          </div>\n        </div>\n      </section>\n\n      <!-- ========== FOOTER ========== -->\n      <footer class=\"hogar-footer\">\n        <!-- Top section: columns -->\n        <div class=\"hogar-footer__top\">\n          <div class=\"hogar-footer__top-inner\">\n            <div class=\"hogar-footer__col\">\n              <h4 class=\"hogar-footer__col-title\">ACERCA DE NOSOTROS</h4>\n              <a href=\"#\" class=\"hogar-footer__link\">Quiénes somos</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Gobierno Corporativo</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Documentos del Sistema de Gobierno Corporativo</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Sobre el Buen Gobierno</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Junta Directiva</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Superintendencia Financiera</a>\n            </div>\n            <div class=\"hogar-footer__col hogar-footer__col--no-title\">\n              <a href=\"#\" class=\"hogar-footer__link\">Sistema de atención al consumidor financiero</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Nuestros asesores</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Reseña Histórica</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Modelo de Sostenibilidad</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Dimensión ambiental</a>\n            </div>\n            <div class=\"hogar-footer__col\">\n              <h4 class=\"hogar-footer__col-title\">INFORMES</h4>\n              <a href=\"#\" class=\"hogar-footer__link\">Informes Financieros</a>\n              <a href=\"#\" class=\"hogar-footer__link\">Informes de Sostenibilidad</a>\n            </div>\n            <div class=\"hogar-footer__col\">\n              <h4 class=\"hogar-footer__col-title\">CONTACTO</h4>\n              <p class=\"hogar-footer__contact-text\">Comuníquese con nosotros, marcando sin costo desde cualquier celular al <strong>#322</strong> o a nivel nacional al <strong>018000 123322</strong>, y de inmediato lo pondremos en contacto con uno de nuestros Asesores.</p>\n              <p class=\"hogar-footer__contact-text\">Si lo prefiere, escríbanos a <img src=\"/Iconos/Group 3 Copy 2.png\" alt=\"WhatsApp\" class=\"hogar-footer__wa-icon\"> <a href=\"#\" class=\"hogar-footer__whatsapp\">WHATSAPP</a></p>\n              <p class=\"hogar-footer__contact-text\">En caso de ser proveedor o intermediario, comuníquese con nuestra línea de atención <strong>#322</strong></p>\n            </div>\n          </div>\n        </div>\n        <!-- Mid section: brand links -->\n        <div class=\"hogar-footer__mid\">\n          <div class=\"hogar-footer__mid-inner\">\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Grupo Bolívar</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Asistencia Bolívar</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Ciencuadras</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Reaseguradores</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Proveedores</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Avalúos de crédito</a>\n            <a href=\"#\" class=\"hogar-footer__brand-link\">Trabaje con nosotros</a>\n          </div>\n        </div>\n        <!-- Bottom section: vigilado + social + legal + copyright -->\n        <div class=\"hogar-footer__bottom\">\n          <div class=\"hogar-footer__bottom-inner\">\n            <div class=\"hogar-footer__vigilado\">\n              <img src=\"/Iconos/NUEVO 2.png\" alt=\"Vigilado Superintendencia Financiera\" class=\"hogar-footer__vigilado-img\">\n            </div>\n            <div class=\"hogar-footer__social\">\n              <img src=\"/Iconos/Group 3243.png\" alt=\"Redes sociales\" class=\"hogar-footer__social-img\">\n            </div>\n            <div class=\"hogar-footer__legal-links\">\n              <a href=\"#\">Términos y condiciones de uso</a>\n              <a href=\"#\">Políticas de Seguridad</a>\n              <a href=\"#\">Políticas de Privacidad</a>\n              <a href=\"#\">Ley FACTA</a>\n            </div>\n            <p class=\"hogar-footer__copyright\">© 2021 - Seguros Bolívar S.A. - Seguros Comerciales S.A. - Todos los derechos reservados</p>\n          </div>\n        </div>\n      </footer>\n    </div>\n  ",
    "updatedAt": "2026-05-20T19:10:43.238Z"
  },
  "step1": {
    "html": "\n    <div class=\"step1-page\" style=\"\">\n      <!-- ========== HEADER SIMPLE ========== -->\n      <header class=\"step-header\">\n        <div class=\"step-header__inner\" style=\"\">\n          <a href=\"#\" class=\"step-header__back\" id=\"btn-back\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\"><path d=\"M13 4L7 10l6 6\" stroke=\"#016D38\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n            VOLVER\n          </a>\n          <div class=\"step-header__logo\">\n            <img src=\"/images/logo-seguros-bolivar.png\" alt=\"Seguros Bolívar\" class=\"step-header__logo-img\">\n          </div>\n        </div>\n      </header>\n\n      <!-- ========== CONTENT ========== -->\n      <div class=\"step1-content\" style=\"\">\n        <!-- Title -->\n        <h1 class=\"step1-title\">¡Configure las coberturas a su medida!</h1>\n\n        <!-- Stepper -->\n        <div class=\"step1-stepper\" style=\"\">\n          <div class=\"step1-stepper__step step1-stepper__step--active\">\n            <div class=\"step1-stepper__bull-wrap\">\n              <div class=\"step1-stepper__bull step1-stepper__bull--active\">\n                <span>1</span>\n              </div>\n            </div>\n            <p class=\"step1-stepper__label step1-stepper__label--active\">Ingrese sus datos</p>\n          </div>\n          <div class=\"step1-stepper__line\"></div>\n          <div class=\"step1-stepper__step\">\n            <div class=\"step1-stepper__bull\">\n              <span>2</span>\n            </div>\n            <p class=\"step1-stepper__label\">Arme su plan</p>\n          </div>\n          <div class=\"step1-stepper__line\"></div>\n          <div class=\"step1-stepper__step\">\n            <div class=\"step1-stepper__bull\">\n              <span>3</span>\n            </div>\n            <p class=\"step1-stepper__label\" style=\"\">Confirme su compra</p>\n          </div>\n          <div class=\"step1-stepper__line\"></div>\n          <div class=\"step1-stepper__step\">\n            <div class=\"step1-stepper__bull\">\n              <span>4</span>\n            </div>\n            <p class=\"step1-stepper__label\" style=\"\">Pague su seguro</p>\n          </div>\n        </div>\n\n        <!-- Form Card -->\n        <div class=\"step1-card\" style=\"\">\n          <!-- Header with icon -->\n          <div class=\"step1-card__header\" style=\"\">\n            <img src=\"/Iconos/Group 4579.png\" alt=\"\" class=\"step1-card__icon\" style=\"\">\n            <h2 class=\"step1-card__title\" style=\"\">Su información personal</h2>\n            <p class=\"step1-card__desc\" style=\"\">Conocer sus datos personales como <strong>propietario</strong> nos permite saber qué tipo de seguro es mejor para usted.</p>\n          </div>\n\n          <!-- Form columns -->\n          <div class=\"step1-card__body\" style=\"\">\n            <!-- Left column: personal data -->\n            <div class=\"step1-card__col-left\" style=\"\">\n              <div class=\"step1-form-row\" style=\"\">\n                <div class=\"step1-form-group step1-form-group--small\">\n                  <label class=\"step1-form-label\" style=\"\">Tipo de documento</label>\n                  <select class=\"step1-input step1-select\" id=\"doc-type\" style=\"\">\n                    <option value=\"cc\">C.C.</option>\n                    <option value=\"ce\">C.E.</option>\n                    <option value=\"nit\">NIT</option>\n                  </select>\n                </div>\n                <div class=\"step1-form-group step1-form-group--large\" style=\"\">\n                  <label class=\"step1-form-label\" style=\"\">Número de documento</label>\n                  <input type=\"text\" class=\"step1-input\" id=\"doc-number\" placeholder=\"Ej: 1111.123.123\" style=\"\">\n                </div>\n              </div>\n              <div class=\"step1-form-group\">\n                <label class=\"step1-form-label\">Fecha de nacimiento</label>\n                <div class=\"step1-input-icon\" style=\"\">\n                  <input type=\"text\" class=\"step1-input\" id=\"birthdate\" placeholder=\"DD / MM / AAAA\" style=\"\">\n                  <img src=\"/Iconos/Icon calendar.png\" alt=\"\" class=\"step1-input-icon__img\">\n                </div>\n              </div>\n              <div class=\"step1-form-group\">\n                <label class=\"step1-form-label\">Género:</label>\n                <div class=\"step1-radio-group\">\n                  <label class=\"step1-radio\">\n                    <input type=\"radio\" name=\"gender\" value=\"mujer\" checked=\"\">\n                    <span class=\"step1-radio__custom\"></span>\n                    <span class=\"step1-radio__text\">Mujer</span>\n                  </label>\n                  <label class=\"step1-radio\">\n                    <input type=\"radio\" name=\"gender\" value=\"hombre\">\n                    <span class=\"step1-radio__custom\"></span>\n                    <span class=\"step1-radio__text\">Hombre</span>\n                  </label>\n                </div>\n              </div>\n            </div>\n\n            <!-- Right column: service type -->\n            <div class=\"step1-card__col-right\" style=\"display: none;\">\n              <h3 class=\"step1-card__question\" style=\"\">¿Cuál de estos casos se ajusta a sus necesidades?</h3>\n              <div class=\"step1-options\" style=\"\">\n                <div class=\"step1-option step1-option--selected\" data-option=\"casa-pertenencias\" style=\"\">\n                  <div class=\"step1-option__radio\">\n                    <span class=\"step1-option__radio-dot\"></span>\n                  </div>\n                  <img src=\"/Iconos/Icon 1.png\" alt=\"\" class=\"step1-option__icon\" style=\"\">\n                  <p class=\"step1-option__label\">Quiero asegurar mi casa y pertenencias</p>\n                </div>\n                <div class=\"step1-option\" data-option=\"casa\" style=\"\">\n                  <div class=\"step1-option__radio\" style=\"\"></div>\n                  <img src=\"/Iconos/Icon 2.png\" alt=\"\" class=\"step1-option__icon\" style=\"\">\n                  <p class=\"step1-option__label\" style=\"\">Quiero asegurar mi casa</p>\n                </div>\n                <div class=\"step1-option\" data-option=\"pertenencias\" style=\"\">\n                  <div class=\"step1-option__radio\"></div>\n                  <img src=\"/Iconos/Icon 3.png\" alt=\"\" class=\"step1-option__icon\">\n                  <p class=\"step1-option__label\" style=\"\">Quiero asegurar mis pertenencias</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- ========== BOTTOM BAR ========== -->\n      <div class=\"step1-bottom\" style=\"\">\n        <button class=\"step1-bottom__btn\" id=\"btn-continue\">Continuar</button>\n      </div>\n    </div>\n  ",
    "updatedAt": "2026-05-20T19:11:06.470Z"
  }
}